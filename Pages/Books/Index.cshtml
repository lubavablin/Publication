@page
@model BookStore.Pages.Books.IndexModel
@{
}
<h1>Ассортимент книг</h1>

<p>
    <a asp-page="Create">Добавить новую книгу</a>
</p>

<table border="1" cellpadding="5">
    <thead>
        <tr>
            <th>Название</th>
            <th>Автор</th>
            <th>Цена</th>
            <th>Количество</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
       @foreach (var book in Model.Books)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Price</td>
                <td>@book.Quantity</td>
                <td>
                    <a asp-page="Details" asp-route-id="@book.Id">Открыть</a>
                    <a asp-page="Edit" asp-route-id="@book.Id">Изменить</a>
                    <a asp-page="Delete" asp-route-id="@book.Id">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>
